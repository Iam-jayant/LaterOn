# API Configuration
API_PORT=4000
QUOTE_TTL_SECONDS=300
DEFAULT_ALGO_PER_INR=0.0022
ADMIN_API_KEY=change-me-in-production

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Authentication
AUTH_REQUIRED=true
AUTH_TOKEN_SECRET=your-secret-key-change-in-production
AUTH_TOKEN_TTL_SECONDS=3600
AUTH_CHALLENGE_TTL_SECONDS=300
DEV_SIGNATURE_BYPASS=false

# Merchant Authentication
MERCHANT_AUTH_REQUIRED=true
MERCHANT_API_KEYS=merchant_demo:demo-key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Idempotency
REQUIRE_IDEMPOTENCY=true

# Algorand TestNet Configuration
CHAIN_ENABLED=true
CHAIN_WAIT_ROUNDS=10
ALGOD_ADDRESS=https://testnet-api.algonode.cloud
ALGOD_TOKEN=

# Deployed Contract App IDs
BNPL_APP_ID=your_bnpl_app_id
POOL_APP_ID=your_pool_app_id

# Relayer (Pool Account)
# Use the same account as LENDING_POOL_ADDRESS
# Provide either MNEMONIC or PRIVATE_KEY (not both)
RELAYER_MNEMONIC=your 25 word mnemonic here
RELAYER_PRIVATE_KEY=

# Reloadly API Configuration (Gift Cards)
RELOADLY_CLIENT_ID=your_client_id
RELOADLY_CLIENT_SECRET=your_client_secret
RELOADLY_BASE_URL=https://giftcards-sandbox.reloadly.com
RELOADLY_AUTH_URL=https://auth.reloadly.com
RELOADLY_TOKEN_CACHE_TTL_SECONDS=3600

# CoinGecko API Configuration
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_RATE_CACHE_TTL_SECONDS=300
COINGECKO_FALLBACK_RATE=0.0022

# Lending Pool Configuration
# This should be the same address as the relayer account
LENDING_POOL_ADDRESS=your_pool_algorand_address

# Marketplace Configuration
MARKETPLACE_MERCHANT_ID=reloadly
MARKETPLACE_TENURE_MONTHS=3

# Algorand Indexer Configuration
INDEXER_ADDRESS=https://testnet-idx.algonode.cloud
INDEXER_TOKEN=

# Score ASA Protocol Account (for credit score tokens)
PROTOCOL_MNEMONIC=your protocol account mnemonic
PROTOCOL_ADDRESS=your_protocol_algorand_address

# DPDP Compliance Configuration
# IP_HASH_SALT: 32+ character random string for hashing IP addresses
IP_HASH_SALT=generate_a_random_32_character_string_here

# Known DeFi App IDs (comma-separated)
KNOWN_DEFI_APP_IDS=21580889,552635992,1166022341
